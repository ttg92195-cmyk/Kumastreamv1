# ============================================================
# Database (Neon PostgreSQL - Vercel Storage)
# ============================================================
# IMPORTANT: Neon Integration auto-adds these vars to Vercel - NO NEED to set manually!
# POSTGRES_PRISMA_URL - Prisma-optimized URL via PgBouncer (connection pooling, preferred)
# POSTGRES_URL_NON_POOLING - Direct connection for migrations
# DATABASE_URL - General pooled connection (has channel_binding, NOT recommended for Prisma)
#
# If using Neon Integration in Vercel, these are set automatically.
# If setting manually, get values from Neon Console → Dashboard → Connection Details.
POSTGRES_PRISMA_URL="postgresql://neondb_owner:your_password@ep-xxxxx-pooler.c-6.us-east-1.aws.neon.tech/neondb?sslmode=require"
POSTGRES_URL_NON_POOLING="postgresql://neondb_owner:your_password@ep-xxxxx.c-6.us-east-1.aws.neon.tech/neondb?sslmode=require"
DATABASE_URL="postgresql://neondb_owner:your_password@ep-xxxxx-pooler.c-6.us-east-1.aws.neon.tech/neondb?sslmode=require"

# ============================================================
# Read-Only Database URL (OPTIONAL but RECOMMENDED for security)
# ============================================================
# Uses a separate Neon role with SELECT-only permissions.
# Public API endpoints use this connection, preventing any data
# modification even if a vulnerability is exploited.
#
# HOW TO SET UP in Neon Console → SQL Editor:
#   1. CREATE ROLE readonly_user WITH PASSWORD 'your_strong_password' LOGIN;
#   2. GRANT SELECT ON ALL TABLES IN SCHEMA public TO readonly_user;
#   3. ALTER DEFAULT PRIVILEGES IN SCHEMA public
#      GRANT SELECT ON TABLES TO readonly_user;
#   4. Create connection string (use pooler host for connection pooling):
#      postgresql://readonly_user:password@ep-xxxxx-pooler.c-6.us-east-1.aws.neon.tech/neondb?sslmode=require
#   5. Set DATABASE_READ_ONLY_URL in Vercel Environment Variables
#
# If NOT set, the app falls back to POSTGRES_PRISMA_URL with
# app-level read-only enforcement (still secure, but less than DB-level).
DATABASE_READ_ONLY_URL="postgresql://readonly_user:your_password@ep-xxxxx-pooler.c-6.us-east-1.aws.neon.tech/neondb?sslmode=require"

# ============================================================
# TMDB API Key
# ============================================================
TMDB_API_KEY="your_tmdb_api_key_here"

# ============================================================
# Admin Credentials (used for login and API authentication)
# ============================================================
# REQUIRED in production - app will crash without these!
ADMIN_USERNAME="your_admin_username"
ADMIN_PASSWORD="your_secure_password_here"

# ============================================================
# Auth Secret (used for signing admin tokens)
# ============================================================
# REQUIRED in production - tokens won't persist across deploys without it
# Generate with: openssl rand -base64 32
AUTH_SECRET="generate_with_openssl_rand_base64_32"

# ============================================================
# Setup Secret (used to protect /api/setup-db endpoint)
# ============================================================
SETUP_SECRET="generate_a_random_string_here"

# ============================================================
# Cron Secret (used to authenticate Vercel cron job for auto-sync)
# ============================================================
# Generate a random string and set it both here and in Vercel Environment Variables
CRON_SECRET="generate_another_random_string_here"
